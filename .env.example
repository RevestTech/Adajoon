# Environment
ENV=production

# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
SYNC_DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (required for rate limiting and caching)
REDIS_URL=redis://localhost:6379

# JWT Secret (REQUIRED - minimum 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secure-secret-here-minimum-32-characters

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
APPLE_CLIENT_ID=your.apple.service.id

# WebAuthn (Passkeys)
WEBAUTHN_RP_ID=yourdomain.com
WEBAUTHN_RP_NAME=Adajoon
WEBAUTHN_ORIGIN=https://yourdomain.com

# API Keys
SYNC_API_KEY=your-sync-api-key

# Stripe (for subscriptions)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Analytics
MIXPANEL_TOKEN=your-mixpanel-token
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com

# External APIs
IPTV_API_BASE=https://iptv-org.github.io/api
RADIO_BROWSER_API=https://de1.api.radio-browser.info

# CORS Origins (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://adajoon.com,https://www.adajoon.com
